{
  "name": "lunix-mono",
  "private": true,
  "version": "0.1.0",
  "description": "lunix monorepo — the web desktop and its embedded terminal",
  "workspaces": [
    "desktop",
    "terminal"
  ],
  "scripts": {
    "build:web": "node scripts/build-web.mjs",
    "dev": "node scripts/dev.mjs",
    "desktop": "npm start -w @lunix/desktop",
    "terminal": "npm start -w @lunix/terminal",
    "terminal:web": "npm run web -w @lunix/terminal"
  },
  "engines": {
    "node": ">=18"
  }
}
